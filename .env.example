# KAMIS 농산물유통정보 Open API 인증 정보
# 발급: https://www.kamis.or.kr -> 고객센터 -> Open-API 신청
# 두 값이 모두 채워져 있으면 실시간 시세를 사용하고,
# 비어 있거나 호출이 실패하면 자동으로 샘플 데이터로 동작합니다.
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# 네이버 검색 API (블로그 레시피 결과). 발급: https://developers.naver.com -> 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 유튜브 데이터 API v3 (영상 레시피 결과). 발급: Google Cloud Console -> YouTube Data API v3
YOUTUBE_API_KEY=
